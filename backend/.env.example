# ============================================
# UBERRIDE BACKEND ENVIRONMENT CONFIGURATION
# ============================================

# Server Configuration
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/uber

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production_min_32_chars

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Multer File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=0.15
SERVICE_TAX_PERCENTAGE=0.05
